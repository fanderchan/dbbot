// Create InnoDB Cluster
// Generated by Ansible

var primaryUri = "{{ mysql_cluster_admin_user }}@{{ innodb_cluster_primary }}:{{ mysql_port }}";
var password = "{{ mysql_cluster_admin_password }}";
var clusterName = "{{ innodb_cluster_name }}";

try {
    print("Connecting to primary instance " + primaryUri + "...\n");
    shell.connect(primaryUri, password);
    
    // Check if cluster already exists
    try {
        var cluster = dba.getCluster(clusterName);
        print("Cluster '" + clusterName + "' already exists.\n");
        print(JSON.stringify(cluster.status(), null, 2));
    } catch (getErr) {
        // Cluster doesn't exist, create it
        print("Creating InnoDB Cluster '" + clusterName + "'...\n");
        
        var cluster = dba.createCluster(clusterName, {
{% if innodb_cluster_multi_primary | default(false) | bool %}
            multiPrimary: true,
            force: true,
{% endif %}
            replicationAllowedHost: "{{ innodb_cluster_replication_allowed_host | default('1%') }}",
            memberWeight: {{ innodb_cluster_member_weight | default(50) }},
            autoRejoinTries: {{ innodb_cluster_auto_rejoin_tries | default(3) }},
            exitStateAction: "{{ innodb_cluster_exit_state_action | default('READ_ONLY') }}",
            expelTimeout: {{ innodb_cluster_expel_timeout | default(5) }}
        });
        
        print("Cluster successfully created.\n");
        print(JSON.stringify(cluster.status(), null, 2));
    }
} catch (err) {
    print("Error: " + err.message + "\n");
    throw err;
}

