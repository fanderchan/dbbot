// Check InnoDB Cluster status
// Generated by Ansible

var primaryUri = "{{ mysql_cluster_admin_user }}@{{ innodb_cluster_primary }}:{{ mysql_port }}";
var password = "{{ mysql_cluster_admin_password }}";
var clusterName = "{{ innodb_cluster_name }}";

try {
    print("Connecting to " + primaryUri + "...\n");
    shell.connect(primaryUri, password);
    
    var cluster = dba.getCluster(clusterName);
    print("Cluster Name: " + clusterName + "\n");
    print("=====================================\n");
    
    var status = cluster.status();
    print(JSON.stringify(status, null, 2));
    print("\n=====================================\n");
    
    // Check topology
    var topology = status.defaultReplicaSet.topology;
    var allOnline = true;
    for (var member in topology) {
        var memberStatus = topology[member].status;
        print("Member " + member + ": " + memberStatus + "\n");
        if (memberStatus !== "ONLINE") {
            allOnline = false;
        }
    }
    
    if (allOnline) {
        print("\nAll cluster members are ONLINE.\n");
    } else {
        print("\nWARNING: Not all members are ONLINE!\n");
    }
    
} catch (err) {
    print("Error checking cluster status: " + err.message + "\n");
    throw err;
}

