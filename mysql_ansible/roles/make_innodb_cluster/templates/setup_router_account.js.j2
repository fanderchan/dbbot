// Setup MySQL Router Account
// Generated by Ansible
// Reference: https://dev.mysql.com/doc/mysql-shell/8.0/en/configuring-router-user.html

var primaryUri = "{{ mysql_cluster_admin_user }}@{{ innodb_cluster_primary }}:{{ mysql_port }}";
var password = "{{ mysql_cluster_admin_password }}";
var clusterName = "{{ innodb_cluster_name }}";
var routerUser = "{{ mysql_router_user }}@{{ innodb_cluster_router_user_sub_net | default('1%') }}";
var routerPassword = "{{ mysql_router_password }}";

try {
    print("Connecting to primary instance " + primaryUri + "...\n");
    shell.connect(primaryUri, password);
    
    var cluster = dba.getCluster(clusterName);
    
    print("Setting up Router account '" + routerUser + "'...\n");
    
    // Use setupRouterAccount to create the Router user with correct privileges
    // If account exists, use update option; otherwise create new
    try {
        cluster.setupRouterAccount(routerUser, {
            password: routerPassword
        });
    } catch (createErr) {
        // If account already exists, try updating it
        if (createErr.message.indexOf("already exists") >= 0) {
            print("Account exists, updating...\n");
            cluster.setupRouterAccount(routerUser, {
                password: routerPassword,
                update: true
            });
        } else {
            throw createErr;
        }
    }
    
    print("Router account '" + routerUser + "' has been configured successfully.\n");
    
} catch (err) {
    print("Error: " + err.message + "\n");
    throw err;
}

