// Add instances to InnoDB Cluster
// Generated by Ansible

var primaryUri = "{{ mysql_cluster_admin_user }}@{{ innodb_cluster_primary }}:{{ mysql_port }}";
var password = "{{ mysql_cluster_admin_password }}";
var clusterName = "{{ innodb_cluster_name }}";

// Secondary instances to add
var secondaryHosts = [
{% for member in innodb_cluster_members %}
{% if member != innodb_cluster_primary %}
    "{{ member }}",
{% endif %}
{% endfor %}
];

try {
    print("Connecting to primary instance " + primaryUri + "...\n");
    shell.connect(primaryUri, password);
    shell.options["dba.restartWaitTimeout"] = 600;   
    var cluster = dba.getCluster(clusterName);
    print("Got cluster '" + clusterName + "'.\n");
    
    var failedInstances = [];
    
    for (var i = 0; i < secondaryHosts.length; i++) {
        var host = secondaryHosts[i];
        print("Adding instance " + host + ":{{ mysql_port }} to cluster...\n");
        
        try {
            // MySQL Shell 8.4+ API - use object format for connection
            cluster.addInstance({
                user: "{{ mysql_cluster_admin_user }}",
                host: host,
                port: {{ mysql_port }},
                password: password
            }, {
                recoveryMethod: "clone"
            });
            print("Instance " + host + ":{{ mysql_port }} successfully added.\n");
        } catch (addErr) {
            if (addErr.message.indexOf("already a member") >= 0 ||
                addErr.message.indexOf("is already part") >= 0) {
                print("Instance " + host + " is already a member of the cluster.\n");
            } else {
                print("ERROR: Failed to add " + host + ": " + addErr.message + "\n");
                failedInstances.push(host);
            }
        }
    }
    
    print("\nFinal cluster status:\n");
    print(JSON.stringify(cluster.status(), null, 2));
    
    // Throw error if any instance failed to add
    if (failedInstances.length > 0) {
        throw new Error("Failed to add instances: " + failedInstances.join(", "));
    }
    
} catch (err) {
    print("Error: " + err.message + "\n");
    throw err;
}
