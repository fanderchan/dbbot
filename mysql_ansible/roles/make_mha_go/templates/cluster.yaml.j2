# Generated by Ansible (dbbot make_mha_go role). Do not edit manually.
# Managed file: {{ mha_go_config_dir }}/cluster.yaml
name: {{ mha_go_cluster_name }}

topology:
  kind: async-single-primary
  single_writer: true
  allow_cascading_replicas: false

controller:
  id: manager-1
  lease:
    backend: local-memory
    ttl: 15s
  monitor:
    interval: 2s
    failure_threshold: 3
    reconfirm_timeout: 5s
  secondary_checks:
{% for slave_ip in slave_ips %}
    - name: db{{ loop.index + 1 }}-observer
      observer_node: db{{ loop.index + 1 }}
      timeout: 3s
{% endfor %}

replication:
  mode: gtid
  semi_sync:
    policy: preferred
    wait_for_replica_count: 1
    timeout: 5s
  salvage:
    policy: salvage-if-possible
    timeout: 30s

{% if mha_go_writer_endpoint_enabled | bool %}
writer_endpoint:
  kind: vip
  target: {{ vip }}
  command: /usr/local/bin/mha_ip_failover.sh
{% else %}
writer_endpoint:
  kind: none
{% endif %}

hooks:
  shell_compat: true

nodes:
  - id: db1
    host: {{ master_ip }}
    port: {{ mysql_port }}
    version_series: "{{ mysql_version | regex_replace('^(\\d+\\.\\d+)\\..*', '\\1') }}"
    expected_role: primary
    candidate_priority: 0
    sql:
      user: {{ mysql_mha_user }}
      password_ref: plain:{{ mysql_mha_password }}

{% for slave_ip in slave_ips %}
  - id: db{{ loop.index + 1 }}
    host: {{ slave_ip }}
    port: {{ mysql_port }}
    version_series: "{{ mysql_version | regex_replace('^(\\d+\\.\\d+)\\..*', '\\1') }}"
    expected_role: replica
    candidate_priority: {{ 100 - (loop.index0 * 10) }}
    sql:
      user: {{ mysql_mha_user }}
      password_ref: plain:{{ mysql_mha_password }}

{% endfor %}
