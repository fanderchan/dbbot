! Keepalived configuration for MySQL Router HA
! Generated by Ansible

global_defs {
    router_id {{ ansible_hostname }}
    script_user root
    enable_script_security
}

vrrp_script check_mysqlrouter {
    script "{{ router_health_check_script }}"
    interval {{ router_keepalived_check_interval }}
    fall {{ router_keepalived_check_fall }}
    rise {{ router_keepalived_check_rise }}
    weight -20
}

vrrp_instance VI_MYSQLROUTER {
    state {{ router_current_node_role }}
    interface {{ router_net_work_interface }}
    virtual_router_id {{ router_keepalived_virtual_router_id }}
    priority {{ router_current_node_priority }}
    advert_int 1
    
    authentication {
        auth_type PASS
        auth_pass {{ router_keepalived_auth_pass }}
    }
    
    virtual_ipaddress {
        {{ router_vip }}/{{ router_vip_netmask }} dev {{ router_net_work_interface }}
    }
    
    track_script {
        check_mysqlrouter
    }
    
    notify_master "{{ router_keepalived_notify_script }} Became MASTER for MySQL Router VIP"
    notify_backup "{{ router_keepalived_notify_script }} Became BACKUP for MySQL Router VIP"
    notify_fault "{{ router_keepalived_notify_script }} FAULT state for MySQL Router VIP"
}
