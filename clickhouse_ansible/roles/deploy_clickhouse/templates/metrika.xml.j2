<?xml version="1.0"?>
<yandex>
    {% set zk_hosts = zookeeper_nodes | default([]) %}
    {% if zk_hosts | length == 0 %}
        {% set zk_hosts = groups['zookeeper_cluster'] | default([]) %}
    {% endif %}
    {% if (zk_hosts | length == 0) and (use_clickhouse_keeper | default(false)) %}
        {% set zk_hosts = groups['clickhouse_cluster'] | default([]) %}
    {% endif %}

    {% if use_clickhouse_keeper | default(false) %}
    <zookeeper-servers>
{% for node in zk_hosts %}
        <node>
{% if node in hostvars %}
            <host>{{ hostvars[node]['ansible_host'] | default(node) }}</host>
{% else %}
            <host>{{ node }}</host>
{% endif %}
            <port>{{ keeper_tcp_port | default(9181) }}</port>
        </node>
{% endfor %}
    </zookeeper-servers>
    {% else %}
    <zookeeper-servers>
{% for node in zk_hosts %}
        <node>
{% if node in hostvars %}
            <host>{{ hostvars[node]['ansible_host'] | default(node) }}</host>
{% else %}
            <host>{{ node }}</host>
{% endif %}
            <port>{{ zookeeper_port | default(2181) }}</port>
        </node>
{% endfor %}
    </zookeeper-servers>
    {% endif %}

    <macros>
        <cluster>{{ clickhouse_cluster_name }}</cluster>
        <shard>{{ current_node_shard }}</shard>
        <replica>{{ current_node_replica_name }}</replica>
    </macros>

    <clickhouse_remote_servers>
        <{{ clickhouse_cluster_name }}>
{% for shard_num in range(1, clickhouse_shard_count | int + 1) %}
            <shard>
                <internal_replication>true</internal_replication>
{% for node in groups['clickhouse_cluster'] %}
{% set node_shard = hostvars[node]['shard'] | default(hostvars[node]['current_node_shard']) | default(1) | int %}
{% set node_replica = hostvars[node]['replica'] | default(hostvars[node]['current_node_replica']) | default(1) | int %}
{% set node_instance_id = hostvars[node]['instance_id'] | default(hostvars[node]['current_node_instance_id']) | default(node_replica) | int %}
{% set node_ip = hostvars[node]['ansible_host'] | default(node) %}
{% if node_shard == shard_num %}
                <replica>
                    <host>{{ node_ip }}</host>
                    <port>{{ (clickhouse_tcp_port_base | default(9000) | int) + (node_instance_id - 1) }}</port>
                    <user>default</user>
                    <password>{{ clickhouse_default_password }}</password>
                </replica>
{% endif %}
{% endfor %}
            </shard>
{% endfor %}
        </{{ clickhouse_cluster_name }}>
    </clickhouse_remote_servers>

    <networks>
        <ip>::/0</ip>
    </networks>

    <clickhouse_compression>
        <case>
            <min_part_size>10000000000</min_part_size>
            <min_part_size_ratio>0.01</min_part_size_ratio>
            <method>lz4</method>
        </case>
    </clickhouse_compression>
</yandex>
